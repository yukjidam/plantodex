# Copy this file to ".env" in the project root and fill in your real keys.
# Never commit the real ".env" file — add it to .gitignore.

PLANTNET_API_KEY=your_plantnet_key_here
PERENUAL_API_KEY=your_perenual_key_here

# Pl@ntNet project to query against. "all" covers the broadest set of species.
PLANTNET_PROJECT=all
